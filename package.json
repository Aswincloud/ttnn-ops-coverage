{
  "name": "ttnn-ops-coverage",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Interactive coverage dashboard for the TTNN operation test matrix.",
  "scripts": {
    "build": "python3 process.py",
    "dev": "wrangler dev",
    "serve": "python3 -m http.server 8080 --bind 0.0.0.0 --directory public",
    "deploy": "npm run build && wrangler deploy",
    "check:data": "python3 scripts/check_data.py",
    "check:code": "node scripts/check_code.mjs",
    "lint": "eslint public/app.js worker/index.js scripts/check_code.mjs",
    "check": "npm run check:data && npm run check:code && npm run lint"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "wrangler": "^4.103.0"
  }
}
